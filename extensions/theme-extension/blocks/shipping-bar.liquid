{% schema %}
{
  "name": "Free Shipping Bar",
  "target": "section",
  "settings": []
}
{% endschema %}
<div class="shipping-bar"
  data-settings-url="https://free-shipping-bar-production-ffdd.up.railway.app/api/settings"
  data-shop="{{ shop.permanent_domain }}"
  data-threshold="7500"
  data-message="Add {amount} more for free shipping!"
  data-success="You've unlocked free shipping!"
  data-color="#1D9E75">
  <div class="shipping-bar__message"></div>
  <div class="shipping-bar__track">
    <div class="shipping-bar__fill"></div>
  </div>
</div>
{{ 'shipping-bar.css' | asset_url | stylesheet_tag }}
<script src="{{ 'shipping-bar.js' | asset_url }}" defer></script>
